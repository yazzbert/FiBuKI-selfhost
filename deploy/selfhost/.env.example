# FiBuKI self-host env — copy to .env next to docker-compose.yml and fill in.
# `docker compose --env-file .env up -d --build`. NEVER commit the filled .env.
# Replace the example.com hostnames with your own web + api domains.

# --- Postgres (Firestore-shim JSONB store) ---
POSTGRES_USER=fibuki
POSTGRES_PASSWORD=CHANGE_ME_pg
POSTGRES_DB=fibuki

# --- MinIO / S3 (storage-shim backend) ---
FIBUKI_S3_ACCESS_KEY=fibuki
FIBUKI_S3_SECRET_KEY=CHANGE_ME_minio
FIBUKI_STORAGE_BUCKET=fibuki-selfhost

# --- Host URLs (your deployment's public web + api origins) ---
FIBUKI_PUBLIC_URL=https://fibuki-api.example.com
FIBUKI_WEB_ORIGIN=https://fibuki.example.com

# --- OIDC (host verifier, oidc-verifier.ts) ---
# Issuer = your OIDC provider's issuer URL (Authentik ends with a slash).
OIDC_ISSUER=https://auth.example.com/application/o/fibuki/
OIDC_AUDIENCE=fibuki-web
OIDC_ADMIN_GROUP=fibuki-admins

# --- SMTP (mailer-shim; From is pinned to FIBUKI_SMTP_USER) ---
FIBUKI_SMTP_HOST=smtp.example.com
FIBUKI_SMTP_PORT=465
FIBUKI_SMTP_SECURE=true
FIBUKI_SMTP_USER=fibuki@example.com
FIBUKI_SMTP_PASS=CHANGE_ME_smtp
FIBUKI_SMTP_FROM_NAME=FiBuKI

# --- Web build args (NEXT_PUBLIC_* — inlined at build; must match the api side) ---
NEXT_PUBLIC_FIBUKI_API_URL=https://fibuki-api.example.com
NEXT_PUBLIC_OIDC_ISSUER=https://auth.example.com/application/o/fibuki/
NEXT_PUBLIC_OIDC_CLIENT_ID=fibuki-web
NEXT_PUBLIC_OIDC_SCOPE=openid profile email offline_access
NEXT_PUBLIC_OIDC_ADMIN_GROUP=fibuki-admins
NEXT_PUBLIC_OIDC_REDIRECT_URI=https://fibuki.example.com/
NEXT_PUBLIC_FIBUKI_POLL_MS=2500
